{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "React: Chrome (localhost:3000)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///src/*": "${webRoot}/src/*",
                "webpack:///*": "${webRoot}/*",
                "webpack:///./*": "${webRoot}/*"
            }
        }
    ]
}